OPENAI_API_KEY=
OPENAI_ANALYSIS_ENABLED=false
OPENAI_WEB_SEARCH_MODEL=gpt-4o-mini-search-preview
PAID_WEB_VERIFICATION_ENABLED=false
NEXT_PUBLIC_APP_URL=https://chamuyocheck.vercel.app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LeasingScoring usa un proyecto Supabase completamente independiente.
# No reutilizar aquí las credenciales de ChamuyoCheck.
NEXT_PUBLIC_LEASING_SUPABASE_URL=
NEXT_PUBLIC_LEASING_SUPABASE_ANON_KEY=

# Pagos futuros. Mantener en false conserva acceso completo para toda cuenta registrada.
BILLING_ENFORCEMENT_ENABLED=false
# Google Workspace/Google OAuth identifica al usuario; no recibe ni liquida cobros.
# Google Pay web requiere un procesador/gateway compatible y aprobación para producción.
GOOGLE_PAY_ENVIRONMENT=TEST
GOOGLE_PAY_MERCHANT_ID=
GOOGLE_PAY_GATEWAY=
GOOGLE_PAY_GATEWAY_MERCHANT_ID=
# Reservado para una futura aplicación Android distribuida por Google Play.
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_SUBSCRIPTION_PRODUCT_ID=
EXTERNAL_VERIFICATION_EXECUTION_ENABLED=false
GOOGLE_SAFE_BROWSING_API_KEY=
