{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": ".",
    "outDir": ".test-dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/analysis/**/*.ts", "app/api/analyze/route.ts", "app/api/verify/route.ts"]
}
